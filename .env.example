# ================================
# DevOps Academy - Environment Variables EXAMPLE
# Copy this to .env and update ALL values before use:
#   cp .env.example .env
# .env is gitignored and must NEVER be committed
# ================================

# Database Configuration
MYSQL_ROOT_PASSWORD=CHANGE_ME_STRONG_ROOT_PASSWORD
MYSQL_DATABASE=legal_education_mysql5
MYSQL_USER=legal_app_user
MYSQL_PASSWORD=CHANGE_ME_STRONG_USER_PASSWORD

# Application Secrets (generate with: openssl rand -base64 48)
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET_MIN_32_CHARS
VIDEO_SECRET=CHANGE_ME_LONG_RANDOM_VIDEO_SECRET

# Admin Credentials
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# n8n
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_N8N_PASSWORD

# Grafana
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# API Configuration
NODE_ENV=production
PORT=5001
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:5001

# File Upload
MAX_FILE_SIZE=5120
UPLOAD_PATH=./uploads
